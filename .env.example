# ARDO Enterprise API deployment configuration
ENV=production
PORT=8000

# Persistence
ENTERPRISE_DATABASE_URL=sqlite:///database/enterprise.db

# Security
# Replace every placeholder before production startup.
API_SECRET_KEY=change-this-to-a-long-random-secret
API_JWT_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_AUTH_USERS=admin:change-this-password
API_INTERNAL_API_KEYS=change-this-internal-service-key

# CORS
API_CORS_ALLOW_ORIGINS=http://localhost:3000
API_CORS_ALLOW_CREDENTIALS=true
API_CORS_ALLOW_METHODS=GET,POST,OPTIONS
API_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,X-Request-ID
